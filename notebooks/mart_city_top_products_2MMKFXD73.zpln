    {
      "text": "%spark.pyspark\nfrom pyspark.sql.window import Window\n\nwindow_spec = Window.partitionBy(\"city\").orderBy(F.col(\"revenue_sum\").desc())\n\ntop_df = agg_df.withColumn(\"rn\", F.row_number().over(window_spec)) \\\n               .filter(F.col(\"rn\") <= 2) \\\n               .drop(\"rn\")\ntop_df.show()\n",
